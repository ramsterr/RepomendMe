---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>RepoRelay — find repos worth your time</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,400..700;1,14..32,400..700&family=Space+Mono:ital,wght@0,400;0,700;1,400;1,700&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,400..700;1,14..32,400..700&family=Space+Mono:ital,wght@0,400;0,700;1,400;1,700&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("rr-theme");
          if (stored === "light" || stored === "dark") {
            document.documentElement.setAttribute("data-theme", stored);
          } else if (window.matchMedia && window.matchMedia("(prefers-color-scheme: light)").matches) {
            document.documentElement.setAttribute("data-theme", "light");
          } else {
            document.documentElement.setAttribute("data-theme", "dark");
          }
        } catch (e) {
          document.documentElement.setAttribute("data-theme", "dark");
        }
      })();
    </script>
    <script is:inline>
      (function () {
        function mulberry32(a) {
          return function () {
            a |= 0;
            a = (a + 0x6d2b79f5) | 0;
            var t = a;
            t = Math.imul(t ^ (t >>> 15), t | 1);
            t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
            return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
          };
        }

        var WEIGHTS = [55, 18, 12, 9, 6];
        var CELL = 20;
        var resizeTimer = null;

        function pickClass(rand) {
          var r = rand() * 100;
          var acc = 0;
          for (var i = 0; i < WEIGHTS.length; i++) {
            acc += WEIGHTS[i];
            if (r < acc) return i;
          }
          return 0;
        }

        function generate() {
          var old = document.getElementById("commit-grid");
          if (old) old.remove();
          var w = window.innerWidth;
          var h = window.innerHeight;
          var cols = Math.ceil(w / CELL) + 1;
          var rows = Math.ceil(h / CELL) + 1;
          var seed = Math.floor(Math.random() * 2147483647);
          var rand = mulberry32(seed);
          var parts = [];
          parts.push(
            '<svg xmlns="http://www.w3.org/2000/svg" width="',
            w,
            '" height="',
            h,
            '" viewBox="0 0 ',
            w,
            " ",
            h,
            '" shape-rendering="crispEdges" preserveAspectRatio="xMidYMid slice">'
          );
          for (var y = 0; y < rows; y++) {
            for (var x = 0; x < cols; x++) {
              var cls = pickClass(rand);
              parts.push(
                '<rect class="c',
                cls,
                '" x="',
                x * CELL,
                '" y="',
                y * CELL,
                '" width="',
                CELL,
                '" height="',
                CELL,
                '"/>'
              );
            }
          }
          parts.push("</svg>");
          var wrap = document.createElement("div");
          wrap.innerHTML = parts.join("");
          var svg = wrap.firstChild;
          svg.id = "commit-grid";
          document.body.appendChild(svg);
        }

        function schedule() {
          if (resizeTimer) clearTimeout(resizeTimer);
          resizeTimer = setTimeout(generate, 200);
        }

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", generate);
        } else {
          generate();
        }
        window.addEventListener("resize", schedule);
      })();
    </script>
  </head>
  <body>
    <main>
      <nav>
        <a href="/" class="logo">RepoRelay</a>
        <div class="links">
          <a href="/" class:list={[Astro.url.pathname === "/" ? "active" : ""]}>home</a>
          <a href="/explore" class:list={[Astro.url.pathname === "/explore" ? "active" : ""]}>explore</a>
          <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle theme" title="Toggle theme">
            <span class="theme-icon" aria-hidden="true">☀</span>
          </button>
        </div>
      </nav>
      <slot />
    </main>
    <script is:inline>
      (function () {
        var btn = document.getElementById("theme-toggle");
        if (!btn) return;
        var icon = btn.querySelector(".theme-icon");
        function refresh() {
          var t = document.documentElement.getAttribute("data-theme") || "dark";
          icon.textContent = t === "dark" ? "☀" : "☾";
          btn.setAttribute("aria-label", t === "dark" ? "Switch to light theme" : "Switch to dark theme");
        }
        refresh();
        btn.addEventListener("click", function () {
          var current = document.documentElement.getAttribute("data-theme") || "dark";
          var next = current === "dark" ? "light" : "dark";
          document.documentElement.setAttribute("data-theme", next);
          try {
            localStorage.setItem("rr-theme", next);
          } catch (e) {}
          refresh();
        });
      })();
    </script>
  </body>
</html>
