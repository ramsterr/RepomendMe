---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>RepoRelay — find repos worth your time</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,400..700;1,14..32,400..700&family=Space+Mono:ital,wght@0,400;0,700;1,400;1,700&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,400..700;1,14..32,400..700&family=Space+Mono:ital,wght@0,400;0,700;1,400;1,700&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <script is:inline>
      (function () {
        var STEPS = ["#0d1117", "#0e4429", "#006d32", "#26a641", "#39d353"];
        var WEIGHTS = [55, 18, 12, 9, 6];
        var CELL = 14;
        var resizeTimer = null;

        function pickShade() {
          var r = Math.random() * 100;
          var acc = 0;
          for (var i = 0; i < WEIGHTS.length; i++) {
            acc += WEIGHTS[i];
            if (r < acc) return STEPS[i];
          }
          return STEPS[0];
        }

        function generate() {
          var old = document.getElementById("commit-grid");
          if (old) old.remove();
          var w = window.innerWidth;
          var h = window.innerHeight;
          var cols = Math.ceil(w / CELL) + 1;
          var rows = Math.ceil(h / CELL) + 1;
          var parts = [];
          parts.push(
            '<svg xmlns="http://www.w3.org/2000/svg" width="',
            w,
            '" height="',
            h,
            '" viewBox="0 0 ',
            w,
            ' ',
            h,
            '" shape-rendering="crispEdges" preserveAspectRatio="xMidYMid slice">'
          );
          for (var y = 0; y < rows; y++) {
            for (var x = 0; x < cols; x++) {
              parts.push(
                '<rect x="',
                x * CELL,
                '" y="',
                y * CELL,
                '" width="',
                CELL,
                '" height="',
                CELL,
                '" fill="',
                pickShade(),
                '"/>'
              );
            }
          }
          parts.push("</svg>");
          var wrap = document.createElement("div");
          wrap.innerHTML = parts.join("");
          var svg = wrap.firstChild;
          svg.id = "commit-grid";
          document.body.appendChild(svg);
        }

        function schedule() {
          if (resizeTimer) clearTimeout(resizeTimer);
          resizeTimer = setTimeout(generate, 200);
        }

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", generate);
        } else {
          generate();
        }
        window.addEventListener("resize", schedule);
      })();
    </script>
  </head>
  <body>
    <main>
      <nav>
        <a href="/" class="logo">RepoRelay</a>
        <div class="links">
          <a href="/" class:list={[Astro.url.pathname === "/" ? "active" : ""]}>home</a>
          <a href="/explore" class:list={[Astro.url.pathname === "/explore" ? "active" : ""]}>explore</a>
        </div>
      </nav>
      <slot />
    </main>
  </body>
</html>
