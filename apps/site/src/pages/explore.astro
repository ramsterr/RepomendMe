---
import Base from "../layouts/Base.astro";
---

<Base>
  <h1>surprise me</h1>
  <p class="subtitle">
    explore repos by topic — pick one, see the top projects, get recommendations
  </p>

  <div class="actions" style="margin-bottom: 1.5rem;">
    <button class="btn btn-outline" id="roll-btn">random repo</button>
    <a href="/" class="btn btn-outline" style="display:inline-block;">back to search</a>
  </div>

  <div id="explore-container">
    <div class="loading">loading topics…</div>
  </div>
</Base>

<script is:inline>
  var API = "http://localhost:8001";

  function fmt(n) {
    if (n >= 1000) return (n / 1000).toFixed(1).replace(/\.0$/, "") + "k";
    return String(n);
  }

  function renderRepos(repos) {
    if (!repos || repos.length === 0) return '<div class="loading">no repos found</div>';
    var html = '<div class="topic-repos">';
    for (var i = 0; i < repos.length; i++) {
      var r = repos[i];
      html +=
        '<a class="repo-chip" href="/repo/' + r.full_name + '">' +
        '<strong>' + r.full_name + '</strong>' +
        ' <span class="stars">' + fmt(r.stars) + ' ★</span>' +
        (r.language ? ' <span class="badge badge-lang">' + r.language + '</span>' : '') +
        '</a>';
    }
    html += '</div>';
    return html;
  }

  function loadTopics() {
    var el = document.getElementById("explore-container");
    if (!el) return;
    el.innerHTML = '<div class="loading">loading topics…</div>';

    fetch(API + "/topics?limit=40")
      .then(function (res) { return res.json(); })
      .then(function (data) {
        var topics = (data.topics || []).filter(function (t) {
          // skip overly broad or spammy tags
          var skip = new Set([
            "hacktoberfest", "hackertoberfest", "good-first-issue",
            "hacktoberfest2022", "hacktoberfest2023", "hacktoberfest2024",
            "hacktoberfest-accepted", "beginner-friendly", "first-timers-only",
            "up-for-grabs", "easy", "help-wanted", "hackoctoberfest",
            "hacktoberfest2020", "hacktoberfest2021",
          ]);
          return !skip.has(t.topic) && t.topic.length < 40;
        }).slice(0, 30);

        var html = '<div class="topic-grid">';
        for (var i = 0; i < topics.length; i++) {
          var t = topics[i];
          html +=
            '<button class="topic-card" data-topic="' + t.topic + '">' +
            '<span class="topic-name">' + t.topic + '</span>' +
            '<span class="topic-count">' + fmt(t.count) + ' repos</span>' +
            '</button>';
        }
        html += '</div><div id="topic-detail"></div>';
        el.innerHTML = html;

        var cards = el.querySelectorAll(".topic-card");
        for (var j = 0; j < cards.length; j++) {
          cards[j].addEventListener("click", function () {
            var topic = this.getAttribute("data-topic");
            var detail = document.getElementById("topic-detail");
            if (!detail) return;
            detail.innerHTML = '<div class="loading">loading ' + topic + '…</div>';
            detail.scrollIntoView({ behavior: "smooth" });

            // mark active card
            var allCards = el.querySelectorAll(".topic-card");
            for (var k = 0; k < allCards.length; k++) {
              allCards[k].classList.remove("active");
            }
            this.classList.add("active");

            fetch(API + "/popular?topic=" + encodeURIComponent(topic) + "&limit=10")
              .then(function (res) { return res.json(); })
              .then(function (data) {
                var titleHtml =
                  '<p class="section-label" style="margin-top: 1rem;">' +
                  'popular <strong>' + topic + '</strong> repos &nbsp;' +
                  '<a href="/repo/' + encodeURIComponent(data.repos[0]?.full_name || '') + '" ' +
                  'class="btn btn-outline" style="display:inline-block;font-size:0.75rem;">' +
                  'recommend from top</a>' +
                  '</p>';
                detail.innerHTML = titleHtml + renderRepos(data.repos);
              })
              .catch(function () {
                detail.innerHTML = '<div class="error">failed to load repos</div>';
              });
          });
        }
      })
      .catch(function () {
        el.innerHTML = '<div class="error">failed to load topics — make sure the API is running on port 8001</div>';
      });
  }

  function roll() {
    var seed = Math.floor(Math.random() * 99999);
    window.location.href = "/repo/" + "?explore&seed=" + seed;
  }

  function exploreRandom() {
    var seed = Math.floor(Math.random() * 99999);
    fetch(API + "/explore?seed=" + seed + "&limit=1")
      .then(function (res) { return res.json(); })
      .then(function (data) {
        window.location.href = "/repo/" + data.source_repo;
      })
      .catch(function () {});
  }

  document.getElementById("roll-btn")?.addEventListener("click", exploreRandom);

  loadTopics();
</script>

<style is:inline>
  .topic-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 0.6rem;
  }

  .topic-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.25rem;
    padding: 0.7rem 0.9rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border, rgba(255, 255, 255, 0.08));
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
    color: inherit;
    font: inherit;
    text-align: left;
  }

  .topic-card:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: var(--accent, #58a6ff);
  }

  .topic-card.active {
    background: rgba(88, 166, 255, 0.12);
    border-color: var(--accent, #58a6ff);
  }

  .topic-name {
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--accent, #58a6ff);
  }

  .topic-count {
    font-size: 0.7rem;
    opacity: 0.5;
  }

  .topic-repos {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .repo-chip {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.7rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border, rgba(255, 255, 255, 0.08));
    border-radius: 5px;
    text-decoration: none;
    color: inherit;
    font-size: 0.85rem;
    transition: background 0.1s;
  }

  .repo-chip:hover {
    background: rgba(255, 255, 255, 0.08);
  }

  .repo-chip strong {
    color: var(--text, #e6edf3);
  }

  .badge-lang {
    font-size: 0.65rem;
    padding: 0.1rem 0.4rem;
    background: rgba(88, 166, 255, 0.15);
    border: 1px solid rgba(88, 166, 255, 0.25);
    border-radius: 3px;
    color: var(--accent, #58a6ff);
  }
</style>
