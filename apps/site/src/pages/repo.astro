---
import Base from "../layouts/Base.astro";

const API = import.meta.env.PUBLIC_API_URL || "http://localhost:8001";
---

<Base>
  <h1 id="page-title">loading...</h1>
  <p class="subtitle">
    <a href="/" style="color: var(--accent-dim);">&larr; back</a>
  </p>

  <div class="filter-bar">
    <input
      type="text"
      id="add-tag"
      placeholder="add filter tag (e.g. react, machine-learning)"
      class="tag-input"
    />
    <button type="button" id="apply-tags" class="btn btn-outline">
      apply
    </button>
    <div class="active-filters" id="active-filters"></div>
  </div>

  <p class="section-label" id="results-header" style="margin-top:0.3rem;">
    <span id="results-label">loading...</span>
  </p>

  <div class="actions">
    <button class="btn btn-outline" id="reroll-btn">
      rerun with new seed
    </button>
  </div>

  <div id="results">
    <div class="loading">searching for similar repos...</div>
  </div>
</Base>

<script define:vars={{ API }}>

  // Extract repo from the URL pathname: /repo/owner/name -> owner/name
  // Falls back to ?repo= query param for local dev (astro dev doesn't
  // have Vercel's rewrite rules).
  function getRepoFromPath() {
    var params = new URLSearchParams(window.location.search);
    var qp = params.get("repo");
    if (qp) return qp;
    var path = window.location.pathname;
    var match = path.match(/^\/repo\/(.+)/);
    if (match) return match[1].replace(/\/+$/, "");
    return "";
  }

  var repo = getRepoFromPath();
  if (repo) {
    document.getElementById("page-title").textContent = repo;
  }

  var _fc = {};
  function cachedFetch(url, opts) {
    opts = opts || {};
    var timeoutMs = opts.timeout || 15000;
    var onSlow = opts.onSlow;
    var now = Date.now();
    if (_fc[url] && now - _fc[url].ts < 300000) {
      return Promise.resolve(_fc[url].data);
    }
    try {
      var sc = sessionStorage.getItem("rr:" + url);
      if (sc) {
        var parsed = JSON.parse(sc);
        if (now - parsed.ts < 300000) {
          _fc[url] = parsed;
          return Promise.resolve(parsed.data);
        }
      }
    } catch (e) {}
    var controller = typeof AbortController !== "undefined" ? new AbortController() : null;
    var timeoutId = setTimeout(function () { if (controller) controller.abort(); }, timeoutMs);
    var slowId = onSlow ? setTimeout(onSlow, 3000) : null;
    var fetchOpts = controller ? { signal: controller.signal } : {};
    return fetch(url, fetchOpts).then(function (res) {
      clearTimeout(timeoutId);
      if (slowId) clearTimeout(slowId);
      if (!res.ok) throw new Error("API " + res.status + " " + (res.statusText || ""));
      return res.text().then(function (text) {
        var data;
        try { data = JSON.parse(text); }
        catch (e) { throw new Error("API returned non-JSON response"); }
        var entry = { data: data, ts: now };
        _fc[url] = entry;
        try { sessionStorage.setItem("rr:" + url, JSON.stringify(entry)); } catch (e) {}
        return data;
      });
    }).catch(function (err) {
      clearTimeout(timeoutId);
      if (slowId) clearTimeout(slowId);
      if (controller && err && err.name === "AbortError") {
        throw new Error("request timed out after " + (timeoutMs / 1000) + "s");
      }
      if (err && err.message && /Failed to fetch|NetworkError|Load failed/i.test(err.message)) {
        throw new Error("API is unreachable &#8212; is the backend running on " + API + "?");
      }
      throw err;
    });
  }

  function cachedFetchWithRetry(url, opts, retries) {
    retries = retries || 1;
    return cachedFetch(url, opts).catch(function (err) {
      if (retries > 0) {
        return new Promise(function (resolve) {
          setTimeout(function () {
            resolve(cachedFetchWithRetry(url, opts, retries - 1));
          }, 2000);
        });
      }
      throw err;
    });
  }

  var currentSeed = (function () {
    var s = new URLSearchParams(window.location.search).get("seed");
    return s ? parseInt(s) : undefined;
  })();
  var currentTags = (function () {
    var raw = new URLSearchParams(window.location.search).get("tags");
    return raw ? raw.split(",").map(function (t) { return t.trim(); }).filter(Boolean) : [];
  })();

  if (currentTags.length > 0) {
    var chipHtml = "";
    for (var i = 0; i < currentTags.length; i++) {
      chipHtml +=
        '<span class="filter-chip">' +
        currentTags[i] +
        '<button type="button" class="remove-filter" data-tag="' + currentTags[i] + '" style="background:none;border:none;color:inherit;cursor:pointer;margin-left:4px;font-size:0.8rem;">\u00d7</button>' +
        '</span>';
    }
    document.getElementById("active-filters").innerHTML = chipHtml;
    document.getElementById("results-label").textContent = "active filters:";
  }

  function fmt(n) {
    if (n >= 1000) return (n / 1000).toFixed(1).replace(/\.0$/, "") + "k";
    return String(n);
  }

  function scoreColor(score) {
    if (score >= 0.7) return "high";
    if (score >= 0.4) return "medium";
    return "low";
  }

  function matchLabel(features) {
    var parts = [];
    if (features.language_match >= 1) parts.push("same language");
    if (features.topic_overlap > 0.3) parts.push("shared topics");
    if (features.cosine_sim > 0.6) parts.push("similar README");
    if (features.filter_cosine_sim > 0.5) parts.push("semantic match");
    if (features.dep_overlap > 0.3) parts.push("shared deps");
    if (parts.length === 0) return "loose match";
    return parts.slice(0, 2).join(" + ");
  }

  function renderResults(repos) {
    var html = "";
    for (var i = 0; i < repos.length; i++) {
      var r = repos[i];
      var otherTopics = (r.topics || []).filter(function (t) { return (r.shared_topics || []).indexOf(t) === -1; }).slice(0, 3);
      html +=
        '<div class="card">' +
        '<div class="card-top">' +
        '<a class="card-repo" href="https://github.com/' + r.full_name + '" target="_blank" rel="noopener">' + r.full_name + '</a>' +
        '<span class="stars">' + fmt(r.stars) + ' \u2605</span>' +
        '</div>' +
        '<div class="card-desc">' + (r.description || "(no description)") + '</div>' +
        '<div class="card-meta">' +
        '<span class="score-dot ' + scoreColor(r.score) + '"></span>' +
        '<span class="badge badge-lang" style="font-size:0.65rem;">' + matchLabel(r.features) + '</span>';
      if (r.shared_language) {
        html += '<span class="badge badge-shared-lang">' + r.language + '</span>';
      }
      if (r.shared_topics && r.shared_topics.length > 0) {
        html += '<span class="badge badge-shared-topics">' + r.shared_topics.join(", ") + '</span>';
      }
      if (r.language && !r.shared_language) {
        html += '<span class="badge badge-lang">' + r.language + '</span>';
      }
      for (var j = 0; j < otherTopics.length; j++) {
        html += '<span class="pill">' + otherTopics[j] + '</span>';
      }
      html += '</div></div>';
    }
    return html;
  }

  function loadRecommendations() {
    var resultsEl = document.getElementById("results");
    var headerEl = document.getElementById("results-label");
    var slowShown = false;

    if (!repo) {
      headerEl.textContent = "";
      resultsEl.innerHTML = '<div class="error">no repo specified &#8212; go <a href="/">home</a> to search</div>';
      return;
    }

    var params = "repo=" + encodeURIComponent(repo) + "&limit=12";
    if (currentSeed !== undefined) params += "&seed=" + currentSeed;
    if (currentTags.length > 0) params += "&tags=" + encodeURIComponent(currentTags.join(","));

    headerEl.textContent = "loading...";
    resultsEl.innerHTML = '<div class="loading" id="results-loading">searching for similar repos...</div>';

    cachedFetchWithRetry(API + "/recommend?" + params, {
      onSlow: function () {
        slowShown = true;
        var el = document.getElementById("results-loading");
        if (el) el.textContent = "still searching... (cold start can take a few seconds)";
      },
    }, 1)
      .then(function (data) {
        var repos = data.repos || [];
        headerEl.textContent = repos.length + " recommendations" + (currentSeed !== undefined ? " (seed: " + currentSeed + ")" : "");
        resultsEl.innerHTML = renderResults(repos);
      })
      .catch(function (e) {
        var msg = (e && e.message) || "failed to load";
        resultsEl.innerHTML =
          '<div class="error">' + msg +
          '<br><button type="button" class="btn btn-outline" style="margin-top:0.75rem;font-size:0.75rem;padding:0.4rem 0.8rem;" id="retry-btn">retry</button>' +
          '</div>';
        var retryBtn = document.getElementById("retry-btn");
        if (retryBtn) retryBtn.addEventListener("click", function () { loadRecommendations(); });
      });
  }

  loadRecommendations();

  function addTag(tag) {
    tag = tag.trim().toLowerCase();
    if (!tag) return;
    if (currentTags.indexOf(tag) === -1) {
      currentTags.push(tag);
      updateTagChips();
      loadRecommendations();
    }
  }

  function removeTag(tag) {
    currentTags = currentTags.filter(function (t) { return t !== tag; });
    updateTagChips();
    loadRecommendations();
  }

  function updateTagChips() {
    var el = document.getElementById("active-filters");
    if (currentTags.length === 0) {
      el.innerHTML = "";
      document.getElementById("results-label").textContent = "";
      return;
    }
    document.getElementById("results-label").textContent = "active filters:";
    var html = "";
    for (var i = 0; i < currentTags.length; i++) {
      html +=
        '<span class="filter-chip">' + currentTags[i] +
        '<button type="button" class="remove-filter" data-tag="' + currentTags[i] + '" style="background:none;border:none;color:inherit;cursor:pointer;margin-left:4px;font-size:0.8rem;">\u00d7</button>' +
        '</span>';
    }
    el.innerHTML = html;
    bindRemoveHandlers();
  }

  function bindRemoveHandlers() {
    var btns = document.querySelectorAll(".remove-filter");
    for (var i = 0; i < btns.length; i++) {
      btns[i].onclick = function () {
        removeTag(this.getAttribute("data-tag"));
      };
    }
  }

  bindRemoveHandlers();

  document.getElementById("apply-tags").addEventListener("click", function () {
    var input = document.getElementById("add-tag");
    addTag(input.value);
    input.value = "";
  });
  document.getElementById("add-tag").addEventListener("keydown", function (e) {
    if (e.key === "Enter") {
      e.preventDefault();
      addTag(this.value);
      this.value = "";
    }
  });

  document.getElementById("reroll-btn").addEventListener("click", function () {
    currentSeed = Math.floor(Math.random() * 99999);
    loadRecommendations();
  });
</script>

<style is:inline>
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .tag-input {
    flex: 1;
    min-width: 240px;
    padding: 0.9rem 1.1rem;
    background: var(--bg-glass, rgba(13, 17, 23, 0.55));
    backdrop-filter: blur(10px) saturate(1.2);
    -webkit-backdrop-filter: blur(10px) saturate(1.2);
    border: 1.5px solid var(--border, #30363d);
    border-radius: 10px;
    color: inherit;
    font: inherit;
    font-size: 0.95rem;
  }

  .tag-input:focus {
    outline: none;
    border-color: var(--accent, #39d353);
  }

  .active-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    width: 100%;
  }

  .filter-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.35rem 0.75rem;
    background: rgba(57, 211, 83, 0.15);
    border: 1px solid rgba(57, 211, 83, 0.35);
    border-radius: 100px;
    font-size: 0.85rem;
    color: var(--accent, #39d353);
    font-family: var(--font-mono, "Space Mono", monospace);
  }

  .loading {
    padding: 1rem 0;
    opacity: 0.6;
  }
</style>
