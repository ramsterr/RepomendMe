---
import { getRecommendations } from "~/lib/api";

const query = Astro.url.searchParams.get("repo") ?? "vercel/next.js";
const data = await getRecommendations(query, 5);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RepoRelay - {query}</title>
  </head>
  <body>
    <main>
      <h1>RepoRelay</h1>
      <p>Recommendations for <code>{query}</code></p>
      {data.slots.length === 0 ? (
        <p><em>No recommendations yet (stub).</em></p>
      ) : (
        <ul>
          {data.slots.map((slot) => (
            <li>
              <h2>{slot.name}</h2>
              {slot.repos.length === 0 ? <p><em>empty</em></p> : null}
            </li>
          ))}
        </ul>
      )}
    </main>
  </body>
</html>
