---
import Base from "../../../layouts/Base.astro";
import {
  fetchRecommendations,
  type RecommendResponse,
} from "../../../lib/api";

const { owner, name } = Astro.params;
const repo = `${owner}/${name}`;
const seedParam = Astro.url.searchParams.get("seed");
const seed = seedParam ? parseInt(seedParam) : undefined;
const tagsParam = Astro.url.searchParams.get("tags");
const tags = tagsParam ? tagsParam.split(",").map(t => t.trim()).filter(Boolean) : undefined;

let data: RecommendResponse | null = null;
let error: string | null = null;

try {
  data = await fetchRecommendations(repo, 12, seed, tags);
} catch (e) {
  error = e instanceof Error ? e.message : "failed to load";
}

function fmt(n: number): string {
  if (n >= 1000) return (n / 1000).toFixed(1).replace(/\.0$/, "") + "k";
  return String(n);
}

function scoreColor(score: number): string {
  if (score >= 0.7) return "high";
  if (score >= 0.4) return "medium";
  return "low";
}

function matchLabel(features: Record<string, number>): string {
  const parts: string[] = [];
  if (features.language_match >= 1) parts.push("same language");
  if (features.topic_overlap > 0.3) parts.push("shared topics");
  if (features.cosine_sim > 0.6) parts.push("similar README");
  if (features.filter_cosine_sim > 0.5) parts.push("semantic match");
  if (features.dep_overlap > 0.3) parts.push("shared deps");
  if (parts.length === 0) return "loose match";
  return parts.slice(0, 2).join(" + ");
}
---

<Base>
  <h1>{repo}</h1>
  <p class="subtitle">
    <a href="/" style="color: var(--accent-dim);">&larr; back</a>
  </p>

  <div class="filter-bar">
    <input
      type="text"
      id="add-tag"
      placeholder="add filter tag (e.g. react, machine-learning)"
      class="tag-input"
    />
    <button type="button" id="apply-tags" class="btn btn-outline" style="font-size:0.75rem;padding:0.3rem 0.7rem;">
      apply
    </button>
    {
      tags && tags.length > 0 && (
        <div class="active-filters">
          {tags.map(t => (
            <span class="filter-chip">
              {t}
              <button
                type="button"
                class="remove-filter"
                data-tag={t}
                style="background:none;border:none;color:inherit;cursor:pointer;margin-left:4px;font-size:0.8rem;"
              >×</button>
            </span>
          ))}
        </div>
      )
    }
  </div>

  {tags && tags.length > 0 && (
    <p class="section-label" style="margin-top:0.3rem;">
      active filters: {tags.map(t => <span class="badge" style="background:#e8f5e9;border-color:#c8e6c9;color:#2e7d32;font-size:0.75rem;">{t}</span>)}
    </p>
  )}

  {
    error ? (
      <div class="error">
        {error}
        <br />
        <small>make sure the API is reachable</small>
      </div>
    ) : (
      <>
        <p class="section-label">
          {data?.repos.length ?? 0} recommendations
          {seed !== undefined && <span style="opacity:0.5"> (seed: {seed})</span>}
        </p>

        <div class="actions">
          <button class="btn btn-outline" id="reroll-btn">
            rerun with new seed
          </button>
        </div>

        <div id="results">
          {data?.repos.map((r) => (
            <div class="card">
              <div class="card-top">
                <a
                  class="card-repo"
                  href={`https://github.com/${r.full_name}`}
                  target="_blank"
                  rel="noopener"
                >
                  {r.full_name}
                </a>
                <span class="stars">{fmt(r.stars)} ★</span>
              </div>
              <div class="card-desc">
                {r.description || "(no description)"}
              </div>
              <div class="card-meta">
                <span class={`score-dot ${scoreColor(r.score)}`} />
                <span class="badge badge-lang" style="font-size:0.65rem;">
                  {matchLabel(r.features)}
                </span>
                {r.shared_language && (
                  <span class="badge badge-lang" style="background:#e8f5e9;border-color:#c8e6c9;color:#2e7d32;">
                    {r.language}
                  </span>
                )}
                {r.shared_topics.length > 0 && (
                  <span class="badge" style="background:#e3f2fd;border-color:#bbdefb;color:#1565c0;">
                    {r.shared_topics.join(", ")}
                  </span>
                )}
                {r.language && !r.shared_language && (
                  <span class="badge badge-lang">{r.language}</span>
                )}
                {r.topics
                  .filter((t) => !r.shared_topics.includes(t))
                  .slice(0, 3)
                  .map((t) => (
                    <span class="pill">{t}</span>
                  ))}
              </div>
            </div>
          ))}
        </div>
      </>
    )
  }
</Base>

<script is:inline>
  function getTags() {
    var raw = new URLSearchParams(window.location.search).get("tags");
    return raw ? raw.split(",").map(function (t) { return t.trim(); }).filter(Boolean) : [];
  }

  function navigateWithTags(newTags) {
    var parts = [window.location.pathname];
    if (newTags.length > 0) parts.push("?tags=" + encodeURIComponent(newTags.join(",")));
    var seed = new URLSearchParams(window.location.search).get("seed");
    if (seed) parts.push(parts.length > 1 ? "&seed=" + seed : "?seed=" + seed);
    window.location.href = parts.join("");
  }

  function addTag(tag) {
    tag = tag.trim().toLowerCase();
    if (!tag) return;
    var tags = getTags();
    if (tags.indexOf(tag) === -1) tags.push(tag);
    navigateWithTags(tags);
  }

  function removeTag(tag) {
    var tags = getTags().filter(function (t) { return t !== tag; });
    navigateWithTags(tags);
  }

  var addInput = document.getElementById("add-tag");
  var applyBtn = document.getElementById("apply-tags");

  if (addInput && applyBtn) {
    applyBtn.addEventListener("click", function () { addTag(addInput.value); addInput.value = ""; });
    addInput.addEventListener("keydown", function (e) {
      if (e.key === "Enter") { e.preventDefault(); addTag(addInput.value); addInput.value = ""; }
    });
  }

  var removeButtons = document.querySelectorAll(".remove-filter");
  for (var i = 0; i < removeButtons.length; i++) {
    removeButtons[i].addEventListener("click", function () {
      removeTag(this.getAttribute("data-tag"));
    });
  }

  document.getElementById("reroll-btn")?.addEventListener("click", function () {
    var seed = Math.floor(Math.random() * 99999);
    var tags = getTags();
    var url = window.location.pathname + "?seed=" + seed;
    if (tags.length > 0) url += "&tags=" + encodeURIComponent(tags.join(","));
    window.location.href = url;
  });
</script>

<style is:inline>
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .tag-input {
    flex: 1;
    min-width: 200px;
    padding: 0.4rem 0.7rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border, rgba(255, 255, 255, 0.12));
    border-radius: 4px;
    color: inherit;
    font: inherit;
    font-size: 0.85rem;
  }

  .tag-input:focus {
    outline: none;
    border-color: var(--accent, #58a6ff);
  }

  .active-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    width: 100%;
  }

  .filter-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    padding: 0.2rem 0.55rem;
    background: rgba(88, 166, 255, 0.12);
    border: 1px solid rgba(88, 166, 255, 0.25);
    border-radius: 3px;
    font-size: 0.75rem;
    color: var(--accent, #58a6ff);
  }
</style>
